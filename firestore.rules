rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading allowedUsers list without auth (needed for login check)
    match /config/allowedUsers {
      allow read: if true;
      // Allow first-time setup: any authenticated user can write
      allow write: if request.auth != null;
    }

    // Allow any authenticated user to create their own signup request
    match /signupRequests/{request} {
      allow read, delete: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/config/allowedUsers).data.uids;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // All other documents require auth + user in allowed list
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/config/allowedUsers).data.uids;
    }
  }
}
